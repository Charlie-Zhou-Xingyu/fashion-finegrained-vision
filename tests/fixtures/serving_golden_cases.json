[
  {
    "id": "attr_fabric_from_request",
    "endpoint": "/v1/mm/qa",
    "method": "POST",
    "description": "Request attributes provided → attribute_answer, no vision warning",
    "request": {
      "query": "这件衣服是什么面料？",
      "attributes": {
        "fabric": {"value": "棉", "attribute_confidence": 0.86, "source": "request_raw"}
      },
      "garment_category": "shirt"
    },
    "expect": {
      "status": "success",
      "data_keys": ["answer", "answer_type", "sources", "meta"],
      "data_answer_type": "attribute_answer",
      "required_meta": {
        "attribute_source": "request",
        "provided_attributes_used": true
      },
      "required_warning_codes": [],
      "forbidden_warning_codes": ["vision_provider_mock", "vision_input_missing"],
      "forbidden_response_substrings": ["SECRET_BASE64_DO_NOT_LEAK"]
    }
  },
  {
