  {
    "id": "rag_retrieve_fiber",
    "endpoint": "/v1/rag/retrieve",
    "method": "POST",
    "description": "RAG retrieve → hits non-empty, source_ref/review_status present",
    "request": {
      "query": "纤维是什么",
      "top_k": 3
    },
    "expect": {
      "status": "success",
      "data_keys": ["query", "normalized_query", "hits", "meta"],
      "hit_required_keys": ["id", "category", "term", "zh_term", "title", "source", "source_type", "review_status"],
      "forbidden_keys_recursive": ["vision", "image_bytes", "SECRET_BASE64"]
    }
  },
